{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "gomod": { "enabled": false },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Hugo version pinned in .hugo-version",
      "managerFilePatterns": ["/^\\.hugo-version$/"],
      "matchStrings": ["^(?<currentValue>\\S+)\\s*$"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "gohugoio/hugo",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Go version pinned in .go-version and go.mod (kept in sync)",
      "managerFilePatterns": ["/^\\.go-version$/", "/^go\\.mod$/"],
      "matchStrings": [
        "^(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*$",
        "^go (?<currentValue>\\d+\\.\\d+\\.\\d+)$"
      ],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "WeasyPrint version pinned in .weasyprint-version",
      "managerFilePatterns": ["/^\\.weasyprint-version$/"],
      "matchStrings": ["^(?<currentValue>\\S+)\\s*$"],
      "datasourceTemplate": "pypi",
      "depNameTemplate": "weasyprint",
      "versioningTemplate": "pep440"
    }
  ]
}
